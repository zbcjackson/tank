# Wake Word Detection
# Enable/disable wake word detection (set to "true" to enable)
VITE_WAKE_WORD_ENABLED=false

# Wake word engine: porcupine | sherpa-onnx | openwakeword
VITE_WAKE_WORD_ENGINE=sherpa-onnx

# Silence timeout in ms — how long after Tank's last response before session ends
VITE_WAKE_WORD_SILENCE_TIMEOUT_MS=30000

# --- Engine-specific settings ---

# Porcupine (requires paid API key from https://console.picovoice.ai/)
VITE_PORCUPINE_ACCESS_KEY=your_access_key_here

# Sherpa-ONNX KWS (free, no API key needed)
# Run: ./scripts/download-wake-word-models.sh sherpa-onnx
VITE_SHERPA_ONNX_KWS_MODEL_DIR=/models/sherpa-onnx-kws

# openWakeWord (free, no API key needed)
# Run: ./scripts/download-wake-word-models.sh openwakeword
VITE_OPENWAKEWORD_MODEL_DIR=/models/openwakeword
VITE_OPENWAKEWORD_KEYWORD=hey_jarvis
# Custom model file (optional — auto-resolved for built-in keywords)
# VITE_OPENWAKEWORD_MODEL_FILE=Hey_Tank_20260324_165700.onnx
# Detection threshold 0-1 (default: 0.25, lower = more sensitive but more false positives)
# VITE_OPENWAKEWORD_THRESHOLD=0.25
