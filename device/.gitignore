# Build output
.pio/

# ESP-IDF managed components (downloaded dependencies, like node_modules)
managed_components/
dependencies.lock

# Environment config (contains secrets)
.env

# Machine-specific PlatformIO overrides (ports, upload settings)
platformio_local.ini

# sdkconfig generated by menuconfig (use sdkconfig.defaults instead)
sdkconfig
sdkconfig.*
!sdkconfig.defaults
